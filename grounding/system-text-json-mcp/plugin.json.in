{
  "name": "dotnet-package-grounding-mcp-stj",
  "version": "0.1.0",
  "description": "MCP delivery environment for package grounding (resident-API probe): registers the get_package_context server so the agent self-selects retrieval.",
  "skills": ["./"],
  "mcpServers": {
    "package-grounding": {
      "command": "dotnet",
      "args": ["__REPO_ROOT__/src/grounding/bin/Release/net11.0/grounding.dll", "mcp", "--root", "__REPO_ROOT__"]
    }
  }
}
