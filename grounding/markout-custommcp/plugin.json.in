{
  "name": "markout-custommcp",
  "version": "0.1.0",
  "description": "Delivery-channel unit: registers our controlled grounding MCP (get_package_context, gate via GROUNDING_GATE) on the Markout task so the agent self-selects retrieval of curated grounding.",
  "skills": ["./"],
  "mcpServers": {
    "package-grounding": {
      "command": "dotnet",
      "args": ["__REPO_ROOT__/src/grounding/bin/Release/net11.0/grounding.dll", "mcp", "--root", "__REPO_ROOT__"]
    }
  }
}
